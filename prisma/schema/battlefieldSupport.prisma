model BattlefieldSupportPack {
  id String @id @default(uuid())
  name String
  source String
  cards BattlefieldSupportCard[]
}

model BattlefieldSupportCard {
  id Int @id @default(autoincrement())
  name String
  group String
  bspCost Int
  pvCost Int
  packId String
  pack BattlefieldSupportPack @relation(fields: [packId], references: [id], onDelete: Cascade)
}